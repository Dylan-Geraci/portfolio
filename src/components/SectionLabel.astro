---
interface Props {
  label: string;
  path?: string;
}

const { label, path } = Astro.props;
const slug = path ?? label.toLowerCase().replace(/\s+/g, "-");
---

<div class="section-label">
  <span class="section-label-path">
    <span class="section-label-tilde">~/</span>{slug}
  </span>
  <span class="section-label-rule" aria-hidden="true"></span>
</div>
