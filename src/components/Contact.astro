---
import SectionLabel from "./SectionLabel.astro";
import { meta } from "../content";
---

<section class="site-container section" id="contact" aria-labelledby="contact-heading">
  <div class="section-label-col">
    <SectionLabel label="Contact" />
  </div>
  <div class="section-content">
    <h2 id="contact-heading" class="contact-heading reveal">
      Open to new-grad SWE roles — let's talk.
    </h2>
    <p class="contact-lead reveal">
      Whether you're hiring or just want to swap notes on systems and ML,
      my inbox is open.
    </p>

    <div class="contact-links reveal">
      <div class="contact-row contact-email-row">
        <span class="mono-label contact-row-key">email</span>
        <span class="email-display" id="email-text">{meta.email}</span>
        <button class="copy-btn" id="copy-email" type="button" aria-label="Copy email address">
          Copy
        </button>
      </div>
      <div class="contact-row">
        <span class="mono-label contact-row-key">linkedin</span>
        <a href={meta.linkedin} target="_blank" rel="noopener noreferrer" class="contact-text-link">
          /in/dylangeraci
        </a>
      </div>
      <div class="contact-row">
        <span class="mono-label contact-row-key">github</span>
        <a href={meta.github} target="_blank" rel="noopener noreferrer" class="contact-text-link">
          @Dylan-Geraci
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
